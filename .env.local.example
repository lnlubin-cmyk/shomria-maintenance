# Supabase — copy this file to .env.local and fill in from your Supabase project
# Settings -> API in the Supabase dashboard

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by the admin screen to create users and bulk-import residents.
# NEVER expose this to the browser — it bypasses row-level security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# govmap API token for the map feature (domain-scoped; safe to ship to browser).
NEXT_PUBLIC_GOVMAP_TOKEN=your-govmap-token
